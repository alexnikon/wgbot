# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=

# YooKassa Configuration
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_RETURN_URL=https://t.me/replace_with_bot_username

# Webhook Configuration
WEBHOOK_URL=
DOMAIN=

# Cascade integration
CASCADE_SERVERS_FILE=/run/secrets/cascade_servers.json
CASCADE_REQUEST_TIMEOUT=20
CASCADE_RESERVATION_MINUTES=30
CASCADE_RETRY_INTERVAL_SECONDS=60
PROVISIONING_LEASE_SECONDS=300

# Webhook protection
WEBHOOK_MAX_BODY_BYTES=65536

# Optional protected JSON diagnostics endpoint: /internal/metrics
INTERNAL_METRICS_TOKEN=

# Logging Configuration
LOG_LEVEL=INFO

# Host-side deployment backups (0 disables the corresponding limit)
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES=20

# Support URL (Telegram link)
SUPPORT_URL=

# Admin notifications (comma-separated Telegram IDs)
ADMIN_TELEGRAM_IDS=

# Tariffs (prices); defaults are used if unset
TARIFF_14_DAYS_STARS=
TARIFF_14_DAYS_RUB=
TARIFF_30_DAYS_STARS=
TARIFF_30_DAYS_RUB=
TARIFF_90_DAYS_STARS=
TARIFF_90_DAYS_RUB=
